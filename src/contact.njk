---
layout: layouts/base.njk
pagination:
  data: allSites
  size: 1
  alias: site
permalink: "{{ site.slug }}/contact/index.html"
title: Contact Us
---

<section class="page-header">
  <div class="container">
    <h1 class="page-title">{{ site.content.contact.title | default('Contact Us') }}</h1>
    <p class="page-description">{{ site.content.contact.description | default('We\'d love to hear from you. Reach out to schedule a tour or ask questions.') }}</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="contact-grid">
      {# Contact Form #}
      <div class="contact-form-container">
        <h2>Send Us a Message</h2>
        <form class="contact-form" action="{{ site.formEndpoint | default('#') }}" method="POST">
          <input type="hidden" name="site" value="{{ site.slug }}">

          <div class="form-group">
            <label for="name">Name *</label>
            <input type="text" id="name" name="name" required>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required>
            </div>
            <div class="form-group">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone">
            </div>
          </div>

          <div class="form-group">
            <label for="move-in">Desired Move-in Date</label>
            <input type="date" id="move-in" name="move_in_date">
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="4"></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-full">Send Message</button>
        </form>
      </div>

      {# Contact Info #}
      <div class="contact-info">
        <h2>Get in Touch</h2>

        {% if site.contact.address %}
          <div class="contact-info-item">
            <h3>Address</h3>
            <p>
              {{ site.contact.address }}<br>
              {{ site.contact.city }}, {{ site.contact.state }} {{ site.contact.zip }}
            </p>
            {% if site.contact.mapUrl %}
              <a href="{{ site.contact.mapUrl }}" target="_blank" class="contact-map-link">Get Directions</a>
            {% endif %}
          </div>
        {% endif %}

        {% if site.contact.phone %}
          <div class="contact-info-item">
            <h3>Phone</h3>
            <p><a href="tel:{{ site.contact.phone | replace('(', '') | replace(')', '') | replace('-', '') | replace(' ', '') }}">{{ site.contact.phone | formatPhone }}</a></p>
          </div>
        {% endif %}

        {% if site.contact.email %}
          <div class="contact-info-item">
            <h3>Email</h3>
            <p><a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a></p>
          </div>
        {% endif %}

        {% if site.officeHours %}
          <div class="contact-info-item">
            <h3>Office Hours</h3>
            <ul class="office-hours">
              {% for hours in site.officeHours %}
                <li><strong>{{ hours.days }}:</strong> {{ hours.hours }}</li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{# Map #}
{% if site.contact.latitude and site.contact.longitude %}
<section class="section section-map">
  <div id="map" class="contact-map" data-lat="{{ site.contact.latitude }}" data-lng="{{ site.contact.longitude }}"></div>
</section>
{% endif %}
